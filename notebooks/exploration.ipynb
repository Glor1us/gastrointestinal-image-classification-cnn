      "cell_type": "code",
      "source": [
        "from pathlib import Path\n",
        "import os, shutil\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "SRC = Path(DATA_ROOT)\n",
        "OUT = Path(SPLIT_ROOT)\n",
        "\n",
        "if OUT.exists():\n",
        "    shutil.rmtree(OUT)\n",
        "OUT.mkdir()\n",
        "\n",
        "classes = sorted([d.name for d in SRC.iterdir() if d.is_dir()])\n",
        "print(\"Classes:\", classes)\n",
        "\n",
        "all_files = []\n",
        "all_labels = []\n",
        "\n",
        "for cls in classes:\n",
        "    files = list((SRC/cls).glob(\"*\"))\n",
        "    for f in files:\n",
        "        all_files.append(str(f))\n",
        "        all_labels.append(cls)\n",
        "\n",
        "# 80% train, 20% temp\n",
        "train_files, temp_files, train_labels, temp_labels = train_test_split(\n",
        "    all_files, all_labels,\n",
        "    test_size=0.20, stratify=all_labels, random_state=42\n",
        ")\n",
        "\n",
        "# 10% val, 10% test\n",
        "val_files, test_files, val_labels, test_labels = train_test_split(\n",
        "    temp_files, temp_labels,\n",
        "    test_size=0.50, stratify=temp_labels, random_state=42\n",
        ")\n",
        "\n",
        "def copy_files(files, labels, subset):\n",
        "    for f, lbl in zip(files, labels):\n",
        "        out_dir = OUT / subset / lbl\n",
        "        out_dir.mkdir(parents=True, exist_ok=True)\n",
        "        shutil.copy(f, out_dir / Path(f).name)\n",
        "\n",
        "copy_files(train_files, train_labels, \"train\")\n",
        "copy_files(val_files, val_labels, \"val\")\n",
        "copy_files(test_files, test_labels, \"test\")\n",
        "\n",
        "print(\"Готово: создан новый сплит 80/10/10\")\n"
      ],
