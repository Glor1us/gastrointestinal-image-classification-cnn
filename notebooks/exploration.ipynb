      "cell_type": "code",
      "source": [
        "# Cell: Inception - training utilities (head training)\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = optim.AdamW(filter(lambda p: p.requires_grad, model_inc.parameters()), lr=1e-4, weight_decay=1e-5)\n",
        "scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.5, patience=3)\n",
        "\n",
        "def train_epoch_inception(model, loader, criterion, optimizer):\n",
        "    model.train()\n",
        "    running_loss = 0.0\n",
        "    correct = 0\n",
        "    total = 0\n",
        "    for inputs, targets in loader:\n",
        "        inputs, targets = inputs.to(device), targets.to(device)\n",
        "        optimizer.zero_grad()\n",
        "\n",
        "        model_output = model(inputs)\n",
        "        if isinstance(model_output, tuple):\n",
        "            outputs, aux_outputs = model_output[0], model_output[1]\n",
        "        else:\n",
        "            outputs, aux_outputs = model_output, None # Should not happen in train() if aux_logits=True\n",
        "\n",
        "        loss1 = criterion(outputs, targets)\n",
        "        loss = loss1\n",
        "        if aux_outputs is not None:\n",
        "            loss2 = criterion(aux_outputs, targets)\n",
        "            loss = loss1 + 0.4 * loss2\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        running_loss += loss.item() * inputs.size(0)\n",
        "        preds = outputs.argmax(dim=1)\n",
        "        correct += (preds == targets).sum().item()\n",
        "        total += targets.size(0)\n",
        "    return running_loss / total, correct / total\n",
        "\n",
        "def eval_epoch_inception(model, loader, criterion):\n",
        "    model.eval()\n",
        "    running_loss = 0.0\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for inputs, targets in loader:\n",
        "            inputs, targets = inputs.to(device), targets.to(device)\n",
        "\n",
        "            model_output = model(inputs)\n",
        "            # In eval mode, InceptionV3 from torchvision returns a single tensor\n",
        "            # even if initialized with aux_logits=True. Handle both cases robustly.\n",
        "            outputs = model_output[0] if isinstance(model_output, tuple) else model_output\n",
        "\n",
        "            loss = criterion(outputs, targets)\n",
        "            running_loss += loss.item() * inputs.size(0)\n",
        "            _, preds = outputs.max(1)\n",
        "            correct += preds.eq(targets).sum().item()\n",
        "            total += targets.size(0)\n",
        "\n",
        "    return running_loss / total, correct / total\n",
        "\n",
        "# Train only head (fc + aux fc) for EPOCHS_HEAD\n",
        "best_val_acc = 0.0\n",
        "history = {'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': []}\n",
        "patience_counter = 0\n",
        "\n",
        "print(\"=== Training head (only classifier layers) ===\")\n",
        "for epoch in range(1, EPOCHS_HEAD + 1):\n",
        "    t0 = time.time()\n",
        "    train_loss, train_acc = train_epoch_inception(model_inc, train_loader_inc, criterion, optimizer)\n",
        "    val_loss, val_acc = eval_epoch_inception(model_inc, val_loader_inc, criterion)\n",
        "    scheduler.step(val_acc)\n",
        "    history['train_loss'].append(train_loss); history['train_acc'].append(train_acc)\n",
        "    history['val_loss'].append(val_loss); history['val_acc'].append(val_acc)\n",
        "    t1 = time.time()\n",
        "    print(f\"Epoch {epoch}/{EPOCHS_HEAD} — train_loss: {train_loss:.4f}, train_acc: {train_acc:.4f}, val_loss: {val_loss:.4f}, val_acc: {val_acc:.4f}, time: {t1-t0:.1f}s\")\n",
        "    # save best\n",
        "    if val_acc > best_val_acc:\n",
        "        best_val_acc = val_acc\n",
        "        torch.save(model_inc.state_dict(), SAVE_PATH)\n",
        "        print(\"  Saved best model (head)\")\n",
        "        patience_counter = 0\n",
        "    else:\n",
        "        patience_counter += 1\n",
        "        if patience_counter >= PATIENCE:\n",
        "            print(\"Early stopping (head) triggered\")\n",
        "            break"
      ],
