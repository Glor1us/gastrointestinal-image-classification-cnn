        "# Cell: Inception - build model (pretrained) and freeze backbone\n",
        "# torchvision.models.inception_v3(pretrained=True, aux_logits=True)\n",
        "model_inc = models.inception_v3(pretrained=True, aux_logits=True)\n",
        "# Replace final fc and aux classifier to match num_classes\n",
        "# main classifier\n",
        "in_features = model_inc.fc.in_features\n",
        "model_inc.fc = nn.Linear(in_features, num_classes)\n",
        "# aux classifier (used during training)\n",
        "if model_inc.aux_logits and hasattr(model_inc, 'AuxLogits'):\n",
        "    aux_in = model_inc.AuxLogits.fc.in_features\n",
        "    model_inc.AuxLogits.fc = nn.Linear(aux_in, num_classes)\n",
        "\n",
        "# Freeze all layers initially\n",
        "for param in model_inc.parameters():\n",
        "    param.requires_grad = False\n",
        "\n",
        "# We'll keep the new fc and aux fc trainable\n",
        "for param in model_inc.fc.parameters():\n",
        "    param.requires_grad = True\n",
        "if model_inc.aux_logits and hasattr(model_inc, 'AuxLogits'):\n",
        "    for param in model_inc.AuxLogits.parameters():\n",
        "        param.requires_grad = True\n",
        "\n",
        "model_inc = model_inc.to(device)\n",
        "print(model_inc)\n"
