        "# Evaluate MobileNetV3\n",
        "model_mn.eval()\n",
        "preds, targets = [], []\n",
        "\n",
        "with torch.no_grad():\n",
        "    for x, y in test_loader_inc:\n",
        "        x = x.to(device)\n",
        "        out = model_mn(x)\n",
        "        p = out.argmax(dim=1).cpu().numpy()\n",
        "        preds.extend(p.tolist())\n",
        "        targets.extend(y.numpy().tolist())\n",
        "\n",
        "from sklearn.metrics import classification_report\n",
        "import pandas as pd\n",
        "\n",
        "rep = classification_report(targets, preds, target_names=classes, output_dict=True)\n",
        "df = pd.DataFrame(rep).transpose()\n",
        "df.to_csv(\"mobilenetv3_classification_report_pt.csv\")\n",
        "\n",
        "print(\"MobileNetV3 Test Accuracy:\", df.loc[\"accuracy\", \"precision\"])\n",
